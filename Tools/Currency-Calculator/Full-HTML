<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Modern Currency Converter</title>
<style>
body {
margin: 0;
height: 100vh;
display: flex;
align-items: center;
justify-content: center;
background: linear-gradient(135deg, #1e3c72, #2a5298);
font-family: Inter, Arial, sans-serif;
}

.card {
background: white;
padding: 50px;
width: 650px; /* ⭐ WIDER */
border-radius: 30px;
box-shadow: 0 25px 60px rgba(0,0,0,0.25);
}

h1 {
margin: 0 0 30px;
text-align: center;
font-size: 32px;
font-weight: 800;
color: #1e3c72;
}

label {
font-size: 17px;
font-weight: 600;
margin-top: 22px;
display: block;
color: #1a1f36;
}

input, select {
width: 100%;
padding: 16px;
margin-top: 10px;
border-radius: 16px;
border: 1px solid #c8d2e6;
font-size: 18px;
background: #f5f7ff;
transition: 0.15s;
}

input:focus, select:focus {
border-color: #4c6fff;
box-shadow: 0 0 0 4px rgba(76,111,255,0.25);
outline: none;
}

.row {
display: flex;
gap: 16px;
margin-top: 12px;
}

.swap-btn {
padding: 16px 20px;
border-radius: 16px;
border: none;
background: #e0e7ff;
color: #2a4fff;
font-weight: 800;
cursor: pointer;
font-size: 18px;
transition: 0.15s;
}

.swap-btn:hover {
background: #d4ddff;
}

.convert-btn {
width: 100%;
padding: 18px;
margin-top: 35px;
border-radius: 18px;
border: none;
background: #2a4fff;
color: white;
font-size: 20px;
font-weight: 800;
cursor: pointer;
transition: 0.15s;
}

.convert-btn:hover {
background: #1f3bcc;
}

#result {
margin-top: 30px;
font-size: 26px;
font-weight: 800;
text-align: center;
color: #1e3c72;
min-height: 32px;
}
</style>
</head>
<body>

<div class="card">
<h1>Currency Converter</h1>

<label>Amount</label>
<input id="amount" type="number" value="1" step="0.01">

<label>Convert</label>
<div class="row">
<select id="from"></select>
<button class="swap-btn" id="swap">⇄</button>
<select id="to"></select>
</div>

<button class="convert-btn" id="convert">Convert</button>

<div id="result"></div>
</div>

<script>
// ⭐ YOUR RATES (1 unit = X USD)
const rates = {
"AUD": 1.39,
"BRL": 4.98,
"CAD": 1.37,
"CHF": 0.78,
"CNY": 6.82,
"EUR": 0.85,
"GBP": 0.74,
"INR": 92.45,
"JPY": 158,
"KRW": 1460.59,
"MXN": 17.23,
"NZD": 1.69,
"SEK": 9.13,
"USD": 1,
"ZAR": 16.20
};

// Full names
const names = {
"AUD": "Australian Dollar",
"BRL": "Brazilian Real",
"CAD": "Canadian Dollar",
"CHF": "Swiss Franc",
"CNY": "Chinese Yuan",
"EUR": "Euro",
"GBP": "British Pound",
"INR": "Indian Rupee",
"JPY": "Japanese Yen",
"KRW": "South Korean Won",
"MXN": "Mexican Peso",
"NZD": "New Zealand Dollar",
"SEK": "Swedish Krona",
"USD": "US Dollar",
"ZAR": "South African Rand"
};

const currencies = Object.keys(rates).sort();

const fromSel = document.getElementById("from");
const toSel = document.getElementById("to");

currencies.forEach(c => {
const label = `${c} – ${names[c]}`;
fromSel.innerHTML += `<option value="${c}">${label}</option>`;
toSel.innerHTML += `<option value="${c}">${label}</option>`;
});

toSel.value = "EUR";

function convert() {
const amount = parseFloat(document.getElementById("amount").value);
const from = fromSel.value;
const to = toSel.value;

const usd = amount / rates[from];
const final = usd * rates[to];

document.getElementById("result").textContent =
`${amount.toFixed(2)} ${from} = ${final.toFixed(2)} ${to}`;
}

document.getElementById("convert").onclick = convert;

document.getElementById("swap").onclick = () => {
const temp = fromSel.value;
fromSel.value = toSel.value;
toSel.value = temp;
convert();
};

convert();
</script>

</body>
</html>

